<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- App theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowBackground">@color/appBackground</item>
    </style>

    <!-- Base container -->
    <style name="AppContainer">
        <item name="android:background">@color/appBackground</item>
    </style>

    <!-- Titles -->
    <style name="PageTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primaryText</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <!-- Settings labels -->
    <style name="SettingsLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primaryText</item>
        <item name="android:paddingTop">12dp</item>
    </style>

    <!-- Seekbars -->
    <style name="SettingsSeekBar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Buttons -->
    <style name="PrimaryButton">
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/rewindButtonColor</item>
        <item name="android:padding">12dp</item>
    </style>

</resources>